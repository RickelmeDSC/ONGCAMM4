# =============================================================
# ONG CAMM4 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env com credenciais reais
# =============================================================

# -------------------------------------------------------------
# BANCO DE DADOS — Neon PostgreSQL
# -------------------------------------------------------------
# URL de conexão via pooler (para uso em runtime / queries normais)
DATABASE_URL="postgresql://SEU_USUARIO:SUA_SENHA@SEU_HOST_POOLER.neon.tech/neondb?sslmode=require&channel_binding=require"

# URL direta sem pooler (obrigatória para migrations do Prisma)
# No Neon: Project → Connection Details → Direct connection
DIRECT_URL="postgresql://SEU_USUARIO:SUA_SENHA@SEU_HOST_DIRETO.neon.tech/neondb?sslmode=require"

# -------------------------------------------------------------
# AUTENTICAÇÃO — JWT
# -------------------------------------------------------------
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="SUBSTITUA_POR_UMA_STRING_ALEATORIA_DE_64_CARACTERES_MINIMO"

# Tempo de expiração do access_token em segundos (3600 = 1 hora)
# O refresh_token dura 30 dias e é gerenciado no banco
JWT_EXPIRATION="3600"

# -------------------------------------------------------------
# SERVIDOR
# -------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -------------------------------------------------------------
# UPLOAD DE ARQUIVOS
# -------------------------------------------------------------
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5
